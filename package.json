{
  "name": "emoji-icon-generator",
  "version": "0.1.3",
  "description": "Generate a complete set of web icon assets (favicon, PWA icons, apple-touch-icon, webmanifest) from a single emoji, rendered with your machine's native emoji font.",
  "keywords": [
    "emoji",
    "favicon",
    "icon",
    "pwa",
    "manifest",
    "apple-touch-icon",
    "generator",
    "cli"
  ],
  "license": "MIT",
  "author": "Matthew Noel",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/matthewnoel/emoji-icon-generator.git"
  },
  "type": "module",
  "bin": {
    "emoji-icon-generator": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "npm run build && vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@napi-rs/canvas": "^0.1.65"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  }
}
